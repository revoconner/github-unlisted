# GitHub App (server-only). From github.com → Settings → Developer settings → GitHub Apps.
GITHUB_APP_ID=
# Paste the full PEM with newlines escaped as \n on a single line.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=

# Public app slug (the part in github.com/apps/<slug>), used for the install link.
NEXT_PUBLIC_GITHUB_APP_SLUG=

# Random secret used to sign the owner login cookie. Generate any long random
# string (e.g. two GUIDs concatenated). Required.
SESSION_SECRET=

# Upstash Redis via the Vercel Marketplace integration (KV_* names) — or the
# native Upstash names. The read-only KV token cannot write; use the RW one.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional: expire share links after N seconds (unset = never).
SHARE_LINK_TTL_SECONDS=
